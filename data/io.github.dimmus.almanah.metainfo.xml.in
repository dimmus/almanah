<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.dimmus.almanah</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <developer id="io.github.dimmus">
    <name>dimmus</name>
  </developer>
  <name>Almanah Diary</name>
  <summary>Keep a diary of your life</summary>
  <description>
    <p>
      Almanah Diary is a personal diary application that lets you record your thoughts,
      experiences, and memories. You can keep a private journal with rich text formatting,
      encryption, and integration with Evolution calendar events.
    </p>
    <p>
      Additional features include printing, hyperlinks, tags, and a list of
      events for each day (tasks and appointments from Evolution when available).
    </p>
  </description>
  <releases>
    <release version="0.12.4" date="2025-01-09" type="stable"/>
    <release version="0.12.3" date="2021-03-05" type="stable"/>
    <release version="0.12.2" date="2020-09-03" type="stable"/>
    <release version="0.12.1" date="2020-09-03" type="stable"/>
    <release version="0.12.0" date="2019-10-07" type="stable"/>
  </releases>
  <screenshots>
    <screenshot height="450" width="800" type="default">
      <image>https://gitlab.gnome.org/GNOME/almanah/raw/HEAD/data/screenshot.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/dimmus/almanah</url>
  <url type="bugtracker">https://github.com/dimmus/almanah/issues</url>
  <url type="vcs-browser">https://github.com/dimmus/almanah</url>
  <update_contact>alvaropg_at_gmail.com</update_contact>
  <translation type="gettext">almanah</translation>
  <content_rating type="oars-1.1" />
  <provides>
    <!-- Previous component id -->
    <id>almanah.desktop</id>
  </provides>
  <launchable type="desktop-id">io.github.dimmus.almanah.desktop</launchable>
</component>
