#: data/org.gnome.Almanah.metainfo.xml.in:7 data/org.gnome.Almanah.desktop.in:2
#: src/ui/main-window.blp:47 src/vala/app/application.vala:128
msgid "Almanah Diary"
msgstr "Almanah Diary"

#: data/org.gnome.Almanah.metainfo.xml.in:8
msgid "Keep a diary of your life"
msgstr ""

#: data/org.gnome.Almanah.metainfo.xml.in:10
msgid ""
"Almanah Diary is an application to allow you to keep a diary of your life."
msgstr ""

#: data/org.gnome.Almanah.metainfo.xml.in:13
msgid ""
"You can encrypt the diary to preserve your privacy. It has editing "
"abilities, including text formatting and printing and shows you a lists of "
"events which happened (on your computer) for each day (such as tasks and "
"appointments from Evolution)."
msgstr ""

#: data/org.gnome.Almanah.desktop.in:3
msgid "Keep a personal diary"
msgstr "Houdt een persoonlijk dagboek bij"

#: data/org.gnome.Almanah.desktop.in:4
msgid "Diary"
msgstr "Dagboek"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Almanah.desktop.in:6
msgid "diary;journal;"
msgstr ""

#: data/org.gnome.almanah.gschema.xml:6
msgid "Database encryption key ID"
msgstr "Database versleutelings-ID"

#: data/org.gnome.almanah.gschema.xml:7
msgid ""
"The ID of the key to use to encrypt and decrypt the database, if Almanah has "
"been built with encryption support. Leave blank to disable database "
"encryption."
msgstr ""
"De ID van de sleutel om te gebruiken om de database te versleutelen en te "
"deversleutelen,  indien Almanah gebouwd is met ondersteuning hiervoor. Laat "
"leeg om versleuteling te deactiveren."

#: data/org.gnome.almanah.gschema.xml:11
msgid "Spell checking language"
msgstr "Taal voor spellingscontrole"

#: data/org.gnome.almanah.gschema.xml:12
msgid "The locale specifier of the language in which to check entry spellings."
msgstr ""
"De taal-aangever van de taal waarin de spelling gecontroleerd moet worden."

#: data/org.gnome.almanah.gschema.xml:16
msgid "Spell checking enabled?"
msgstr "Spellingcontrole geactiveerd?"

#: data/org.gnome.almanah.gschema.xml:17
msgid "Whether spell checking of entries is enabled."
msgstr "Of spellingcontrole is geactiveerd."

